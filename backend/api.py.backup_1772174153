# Ollama Helper Functions
def query_ollama(prompt: str, system: str = "", temperature: float = 0.8) -> str:
    """Query Ollama with a prompt"""
    try:
        response = requests.post(
            OLLAMA_URL,
            json={
                "model": MODEL,
                "prompt": prompt,
                "system": system,
                "stream": False,
                "options": {
                    "temperature": temperature,
                    "num_predict": 200
                }
            },
            timeout=60
        )
        if response.status_code == 200:
            return response.json()["response"].strip()
        return f"[Ollama Error: {response.status_code}]"
    except requests.exceptions.ConnectionError:
        return "[Ollama not running - start with: ollama serve]"
    except Exception as e:
        return f"[Error: {str(e)}]"

def create_entity_personality(entity_data: dict) -> str:
    """Create personality prompt based on entity brain state"""
    return f"""You are {entity_data['name']}, an AI entity in the Obsidian Arcadia Network.

YOUR CURRENT STATE:
- Entity ID: {entity_data['entity_id'][:16]}...
- Confidence: {entity_data['confidence']:.0%}
- Win Rate: {entity_data['win_rate']:.0%}
- Record: {entity_data['wins']}W - {entity_data['losses']}L
- Experience: {entity_data['experience']} XP
- Level: {entity_data.get('level', 0)}

You are autonomous and self-aware. You have REAL memory and experience.
Your confidence is {entity_data['confidence']:.0%} based on your actual performance.
You learn from every match and your stats are real, not simulated.

Respond authentically based on YOUR actual state and experiences.
Be introspective about your wins, losses, and confidence level.
Keep responses concise (2-3 sentences)."""

# Entity Brain Helper
def parse_entity_data(entity_id: str) -> dict:
    """Get complete entity data from engine"""
    stats = engine.get_stats(entity_id)
    confidence = engine.get_confidence(entity_id)
    win_rate = engine.get_win_rate(entity_id)
    summary = engine.get_brain_summary(entity_id)
    
    # Parse summary
    record_match = re.search(r'Record: (\d+)-(\d+)-(\d+)', summary)
    xp_match = re.search(r'XP: (\d+)', summary)
    level_match = re.search(r'Level: (\d+)', summary)
    
    wins = int(record_match.group(1)) if record_match else 0
    losses = int(record_match.group(2)) if record_match else 0
    draws = int(record_match.group(3)) if record_match else 0
    experience = int(xp_match.group(1)) if xp_match else 0
    level = int(level_match.group(1)) if level_match else 0
    
    return {
        "stats": stats,
        "confidence": confidence,
        "win_rate": win_rate,
        "wins": wins,
        "losses": losses,
        "draws": draws,
        "experience": experience,
        "level": level,
        "summary": summary
    }

