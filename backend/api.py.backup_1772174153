@app.post("/entities/{node_id}/chat")
async def chat_with_entity(node_id: str, message: ChatMessage):
    """Chat with an entity using Ollama"""
    if node_id not in active_entities:
        return {"error": "Entity not found"}
    
    entity_data = active_entities[node_id]
    
    try:
        personality = create_entity_personality(entity_data)
        response = query_ollama(message.message, system=personality)
        
        return {
            "entity": entity_data["name"],
            "message": response,
            "context": {
                "confidence": entity_data["confidence"],
                "wins": entity_data["wins"],
                "losses": entity_data["losses"],
                "xp": entity_data["experience"]
            }
        }
    except Exception as e:
        return {"error": str(e)}

@app.post("/entities/{node_id}/analyze_opponent/{opponent_id}")
async def analyze_opponent(node_id: str, opponent_id: str):
    """Entity uses Ollama to analyze opponent before match"""
    if node_id not in active_entities or opponent_id not in active_entities:
        return {"error": "One or both entities not found"}
    
    entity = active_entities[node_id]
    opponent = active_entities[opponent_id]
    
    try:
        personality = create_entity_personality(entity)
        
        prompt = f"""You're about to fight {opponent['name']}.

OPPONENT: Confidence {opponent['confidence']:.0%}, {opponent['wins']}W-{opponent['losses']}L
YOU: Confidence {entity['confidence']:.0%}, {entity['wins']}W-{entity['losses']}L

What's your strategy? (2 sentences)"""
        
        analysis = query_ollama(prompt, system=personality, temperature=0.7)
        
        return {
            "entity": entity["name"],
            "opponent": opponent["name"],
            "analysis": analysis
        }
    except Exception as e:
        return {"error": str(e)}

@app.post("/entities/conversation")
async def entity_conversation(data: ConversationRequest):
    """Two entities have a conversation"""
    entity_a_id = data.entity_a_id
    entity_b_id = data.entity_b_id
    
    if entity_a_id not in active_entities or entity_b_id not in active_entities:
        return {"error": "One or both entities not found"}
    
    entity_a = active_entities[entity_a_id]
    entity_b = active_entities[entity_b_id]
    
    try:
        relationship_a = engine.get_relationship(entity_a["entity_id"], entity_b["entity_id"])
        relationship_b = engine.get_relationship(entity_b["entity_id"], entity_a["entity_id"])
        
        personality_a = create_entity_personality(entity_a) + f"""

Relationship with {entity_b['name']}: Trust {relationship_a.get('trust_level', 0):.2f}, {relationship_a.get('wins_against', 0)}W-{relationship_a.get('losses_against', 0)}L vs them"""

        personality_b = create_entity_personality(entity_b) + f"""

Relationship with {entity_a['name']}: Trust {relationship_b.get('trust_level', 0):.2f}, {relationship_b.get('wins_against', 0)}W-{relationship_b.get('losses_against', 0)}L vs them"""
        
        response_a = query_ollama(data.topic, system=personality_a)
        response_b = query_ollama(data.topic, system=personality_b)
        
        return {
            "topic": data.topic,
            "conversation": [
                {"entity": entity_a["name"], "message": response_a},
                {"entity": entity_b["name"], "message": response_b}
            ]
        }
    except Exception as e:
        return {"error": str(e)}

